# AWS credentials / profile
AWS_PROFILE=default
AWS_REGION=eu-west-1

# Optional: pin to a specific ECS cluster (skip auto-discovery scan)
# If unset, bootstrap scans all clusters for a service matching the given name prefix.
ECS_CLUSTER=ecs-cluster-preprod
# Bedrock model (Claude Sonnet via cross-region inference)
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_REGION=us-east-1

# Secrets Manager secret name (contains ELK, Mongo, Redis, Jenkins creds)
SECRET_NAME=ocl-devops-ai-automation

# Output directory for RCA files
OUTPUT_DIR=./output
